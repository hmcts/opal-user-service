{
  "version": "1.0",
  "name": "Opal User Service REST API Collection",
  "type": "workspace",
  "settings": {
    "requestTimeout": 30000,
    "followRedirects": true,
    "prettyPrintResponse": true,
    "validateSSL": false
  },
  "envs": {
    "default": "local",
    "paths": [
      "./environments"
    ]
  },
  "collections": [
    {
      "name": "Get Bearer Token",
      "path": "./collections/Get-BearerToken"
    }
  ]
}
